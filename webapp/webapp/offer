<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Narx kiriting</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: var(--tg-theme-bg-color, #fff);
  color: var(--tg-theme-text-color, #000);
  padding-bottom: 90px;
}
.header {
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  padding: 14px 16px 10px;
  position: sticky; top: 0; z-index: 10;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}
.header h1 { font-size: 17px; font-weight: 600; }
.header p  { font-size: 12px; opacity: .55; margin-top: 2px; }

.progress-bar {
  height: 3px;
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  position: sticky; top: 56px; z-index: 9;
}
.progress-fill {
  height: 100%;
  background: var(--tg-theme-button-color, #007aff);
  transition: width .3s;
}

/* Loading */
.loading {
  display: flex; align-items: center; justify-content: center;
  padding: 60px 16px;
  flex-direction: column; gap: 12px;
  color: var(--tg-theme-hint-color, #888);
  font-size: 14px;
}
.spinner {
  width: 28px; height: 28px;
  border: 2.5px solid var(--tg-theme-secondary-bg-color, #ddd);
  border-top-color: var(--tg-theme-button-color, #007aff);
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Item card */
.item {
  border-bottom: 1px solid rgba(0,0,0,0.07);
  background: var(--tg-theme-bg-color, #fff);
  padding: 12px 16px;
}
.item.unavail { opacity: .45; }

.item-header {
  display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
}
.item-num {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  color: var(--tg-theme-hint-color, #888);
  font-size: 11px; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.item-num.done {
  background: #E2EFDA; color: #3B6D11;
}
.item-name { font-size: 15px; font-weight: 600; flex: 1; }
.item-qty  { font-size: 12px; color: var(--tg-theme-hint-color, #888); }

/* Price input row */
.price-row {
  display: flex; align-items: center; gap: 8px;
}
.price-input-wrap {
  flex: 1; position: relative;
}
.price-input {
  width: 100%; height: 40px;
  border: 1.5px solid rgba(0,0,0,0.12);
  border-radius: 10px;
  font-size: 16px; font-weight: 500;
  padding: 0 44px 0 12px;
  background: var(--tg-theme-bg-color, #fff);
  color: var(--tg-theme-text-color, #000);
  outline: none;
  transition: border-color .15s;
  -webkit-appearance: none;
}
.price-input:focus { border-color: var(--tg-theme-button-color, #007aff); }
.price-input.filled { border-color: #3B6D11; background: #f8fdf5; }
.price-suffix {
  position: absolute; right: 10px; top: 50%;
  transform: translateY(-50%);
  font-size: 12px; color: var(--tg-theme-hint-color, #888);
  pointer-events: none;
}
.unavail-btn {
  height: 40px; padding: 0 12px;
  border: 1.5px solid rgba(0,0,0,0.10);
  border-radius: 10px; font-size: 12px;
  background: transparent;
  color: var(--tg-theme-hint-color, #888);
  cursor: pointer; white-space: nowrap;
  -webkit-tap-highlight-color: transparent;
  transition: all .15s;
  flex-shrink: 0;
}
.unavail-btn.active {
  background: #FCEBEB; border-color: #F09595;
  color: #A32D2D;
}

/* Note input */
.price-hint {
  font-size: 12px;
  color: #3B6D11;
  margin-top: 4px;
  font-weight: 500;
  display: none;
}
.note-input {
  width: 100%; margin-top: 8px;
  border: 1.5px solid rgba(0,0,0,0.08);
  border-radius: 10px;
  font-size: 14px; padding: 8px 12px;
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  color: var(--tg-theme-text-color, #000);
  outline: none; resize: none;
  font-family: inherit; min-height: 36px;
}
.note-input:focus { border-color: var(--tg-theme-button-color, #007aff); }

/* Delivery */
.delivery-row {
  padding: 10px 16px;
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
.delivery-label { font-size: 13px; opacity: .55; margin-bottom: 8px; }
.chips { display: flex; gap: 8px; flex-wrap: wrap; }
.chip {
  padding: 6px 14px; border-radius: 16px;
  border: 1px solid rgba(0,0,0,0.12);
  font-size: 13px; font-weight: 500;
  cursor: pointer; background: transparent;
  color: var(--tg-theme-text-color, #000);
  -webkit-tap-highlight-color: transparent;
}
.chip.sel {
  background: var(--tg-theme-button-color, #007aff);
  color: var(--tg-theme-button-text-color, #fff);
  border-color: transparent;
}

/* Bottom */
.bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 8px 16px 12px;
  background: var(--tg-theme-bg-color, #fff);
  border-top: 1px solid rgba(0,0,0,0.08); z-index: 20;
}
.bottom-info {
  display: flex; justify-content: space-between;
  font-size: 12px; color: var(--tg-theme-hint-color, #888);
  margin-bottom: 8px;
}
.total-sum { font-weight: 600; color: var(--tg-theme-button-color, #007aff); }
.send-btn {
  width: 100%; padding: 14px; border: none; border-radius: 12px;
  background: var(--tg-theme-button-color, #007aff);
  color: var(--tg-theme-button-text-color, #fff);
  font-size: 16px; font-weight: 600; cursor: pointer;
  -webkit-tap-highlight-color: transparent; transition: opacity .15s;
}
.send-btn:active { opacity: .8; }
.send-btn:disabled { opacity: .35; cursor: not-allowed; }
</style>
</head>
<body>

<div class="header">
  <h1>💰 Narx kiriting</h1>
  <p id="subtitle">Yuklanmoqda...</p>
</div>
<div class="progress-bar"><div class="progress-fill" id="progress" style="width:0%"></div></div>

<div id="content"><div class="loading"><div class="spinner"></div>Yuklanmoqda...</div></div>

<div class="delivery-row">
  <div class="delivery-label">🚚 Yetkazib berish muddati:</div>
  <div class="chips">
    <button class="chip sel" data-val="2"   onclick="selDel(this)">⚡️ 2 soat</button>
    <button class="chip"     data-val="24"  onclick="selDel(this)">🕐 24 soat</button>
    <button class="chip"     data-val="48"  onclick="selDel(this)">📅 2 kun</button>
    <button class="chip"     data-val="168" onclick="selDel(this)">🗓 1 hafta</button>
  </div>
</div>

<div class="bottom">
  <div class="bottom-info">
    <span id="filled-count">0/0 to'ldirildi</span>
    <span class="total-sum" id="total-sum"></span>
  </div>
  <button class="send-btn" id="send-btn" onclick="send()" disabled>✅ Taklif yuborish</button>
</div>

<script>
const tg = window.Telegram?.WebApp;
if (tg) { tg.ready(); tg.expand(); }

const params   = new URLSearchParams(window.location.search);
const batchId  = parseInt(window.location.pathname.split('/').pop()) || 0;
let delivery   = 2;
let needs      = [];

// ── API dan ehtiyojlarni yuklash ─────────────────────────────────────────────
async function load() {
  if (!batchId) {
    showError("Buyurtma topilmadi.");
    return;
  }
  try {
    const r = await fetch('/api/needs/' + batchId);
    if (!r.ok) throw new Error('status ' + r.status);
    needs = await r.json();
    if (!needs || needs.length === 0) {
      showError("Bu buyurtmada mahsulot yo'q.");
      return;
    }
    render();
  } catch(e) {
    showError("Yuklab bo'lmadi: " + e.message);
  }
}

function showError(msg) {
  document.getElementById('content').innerHTML =
    '<div class="loading">' + msg + '</div>';
  document.getElementById('subtitle').textContent = 'Xato';
}

// ── Ro'yxatni chizish ─────────────────────────────────────────────────────────
function render() {
  document.getElementById('subtitle').textContent =
    needs.length + ' ta mahsulot';

  let html = '';
  needs.forEach(function(n, i) {
    html +=
      '<div class="item" id="item-' + n.id + '">' +
        '<div class="item-header">' +
          '<div class="item-num" id="num-' + n.id + '">' + (i+1) + '</div>' +
          '<div class="item-name">' + esc(n.name) + '</div>' +
          '<div class="item-qty">Kerak: ' + n.qty + ' ' + n.unit + '</div>' +
        '</div>' +
        '<div class="price-row">' +
          '<div class="price-input-wrap">' +
            '<input class="price-input" id="price-' + n.id + '" type="number" ' +
              'inputmode="numeric" placeholder="Narx..." min="0" ' +
              'oninput="onPrice(' + n.id + ')" ' +
              'onfocus="onFocus(' + n.id + ')">' +
            '<span class="price-suffix">so\'m/'+n.unit+'</span>' +
          '<div class="price-hint" id="hint-' + n.id + '"></div>' +
          '</div>' +
          '<button class="unavail-btn" id="unavail-' + n.id + '" ' +
            'onclick="toggleUnavail(' + n.id + ')">' +
            'Mavjud emas' +
          '</button>' +
        '</div>' +
        '<textarea class="note-input" id="note-' + n.id + '" ' +
          'placeholder="Izoh... (brend, sifat, muddat)" rows="1" ' +
          'oninput="autoResize(this)"></textarea>' +
      '</div>';
  });
  document.getElementById('content').innerHTML = html;
  refresh();
}

function esc(s) {
  return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = el.scrollHeight + 'px';
}

// ── Price handlers ────────────────────────────────────────────────────────────
function onFocus(id) {
  // Mavjud emas belgisini olib tashlaymiz
  var btn = document.getElementById('unavail-' + id);
  if (btn && btn.classList.contains('active')) return; // hali unavail
}

function onPrice(id) {
  var input = document.getElementById('price-' + id);
  var val   = parseFloat(input.value);
  var need  = needs.find(function(n){ return n.id === id; });
  var hint  = document.getElementById('hint-' + id);
  if (val > 0) {
    input.classList.add('filled');
    var btn = document.getElementById('unavail-' + id);
    if (btn) btn.classList.remove('active');
    var item = document.getElementById('item-' + id);
    if (item) item.classList.remove('unavail');
    // Jami hisob
    if (hint && need) {
      var total = val * need.qty;
      hint.textContent = need.qty + ' ' + need.unit + ' × ' + val.toLocaleString() + ' = ' + total.toLocaleString() + " so'm";
      hint.style.display = 'block';
    }
  } else {
    input.classList.remove('filled');
    if (hint) hint.style.display = 'none';
  }
  refresh();
  if (tg && tg.HapticFeedback && val > 0) tg.HapticFeedback.selectionChanged();
}

function toggleUnavail(id) {
  var btn   = document.getElementById('unavail-' + id);
  var input = document.getElementById('price-' + id);
  var item  = document.getElementById('item-' + id);
  var isOn  = btn.classList.toggle('active');
  if (isOn) {
    input.value = '';
    input.classList.remove('filled');
    input.disabled = true;
    if (item) item.classList.add('unavail');
    if (tg && tg.HapticFeedback) tg.HapticFeedback.impactOccurred('light');
  } else {
    input.disabled = false;
    if (item) item.classList.remove('unavail');
    input.focus();
  }
  refresh();
}

// ── Refresh summary ───────────────────────────────────────────────────────────
function refresh() {
  var filled = 0;
  var total  = 0;
  needs.forEach(function(n) {
    var price  = parseFloat(document.getElementById('price-' + n.id)?.value) || 0;
    var unavail= document.getElementById('unavail-' + n.id)?.classList.contains('active');
    var num    = document.getElementById('num-' + n.id);
    if (unavail) {
      filled++;
      if (num) { num.textContent = '—'; num.classList.add('done'); }
    } else if (price > 0) {
      filled++;
      total += price * n.qty;
      if (num) { num.classList.add('done'); }
    } else {
      var idx = needs.indexOf(n);
      if (num) { num.textContent = idx+1; num.classList.remove('done'); }
    }
  });

  // Progress
  var pct = needs.length > 0 ? Math.round(filled/needs.length*100) : 0;
  document.getElementById('progress').style.width = pct + '%';
  document.getElementById('filled-count').textContent =
    filled + '/' + needs.length + ' to\'ldirildi';

  // Total
  var ts = document.getElementById('total-sum');
  if (total > 0) {
    ts.textContent = 'Jami: ' + total.toLocaleString() + ' so\'m';
  } else {
    ts.textContent = '';
  }

  // Send button
  var btn = document.getElementById('send-btn');
  btn.disabled = filled === 0;
  if (filled === needs.length) {
    btn.textContent = '✅ Taklif yuborish';
  } else if (filled > 0) {
    btn.textContent = '✅ ' + filled + ' ta narx yuborish';
  } else {
    btn.textContent = 'Narx kiriting';
  }
}

function selDel(el) {
  document.querySelectorAll('.chip').forEach(function(c){ c.classList.remove('sel'); });
  el.classList.add('sel');
  delivery = parseInt(el.dataset.val);
}

// ── Yuborish ─────────────────────────────────────────────────────────────────
function send() {
  var offers = [];
  needs.forEach(function(n) {
    var priceEl  = document.getElementById('price-' + n.id);
    var unavEl   = document.getElementById('unavail-' + n.id);
    var noteEl   = document.getElementById('note-' + n.id);
    var price    = parseFloat((priceEl && priceEl.value) || 0) || 0;
    var unavail  = unavEl ? unavEl.classList.contains('active') : false;
    var note     = noteEl ? (noteEl.value || '').trim() : '';
    if (unavail) {
      offers.push({ need_id: n.id, price: 0, unavailable: true, note: note });
    } else if (price > 0) {
      offers.push({ need_id: n.id, price: price, unavailable: false, note: note });
    }
  });

  if (offers.length === 0) return;

  var payload = JSON.stringify({
    type:     'offer',
    batch_id: batchId,
    offers:   offers,
    delivery: delivery,
  });

  // sendData faqat bot ichida ochilgan Mini App da ishlaydi
  // Kanal postidan ochilganda tg.initDataUnsafe.query_id yo'q bo'ladi
  var canSendData = tg && tg.initDataUnsafe && tg.initDataUnsafe.query_id;

  if (canSendData) {
    // Bot ichida ochilgan — to'g'ridan yuboramiz
    tg.sendData(payload);
  } else if (tg) {
    // Kanal/boshqa joydan — inline_query orqali yubora olmaymiz
    // Foydalanuvchiga botga o'tishni so'raymiz
    var btn = document.getElementById('send-btn');
    if (btn) {
      btn.textContent = '⏳ Yuklanmoqda...';
      btn.disabled = true;
    }
    // API ga to'g'ridan POST qilamiz
    fetch('/api/submit_offer', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        payload: payload,
        user_id: tg.initDataUnsafe && tg.initDataUnsafe.user && tg.initDataUnsafe.user.id,
        init_data: tg.initData,
      })
    }).then(function(r){ return r.json(); }).then(function(res){
      if (res.ok) {
        if (btn) { btn.textContent = '✅ Yuborildi!'; }
        setTimeout(function(){ tg.close(); }, 1200);
      } else {
        if (btn) { btn.textContent = '✅ Taklif yuborish'; btn.disabled = false; }
        alert('Xato: ' + (res.error || 'nomalum'));
      }
    }).catch(function(e){
      if (btn) { btn.textContent = '✅ Taklif yuborish'; btn.disabled = false; }
      alert('Tarmoq xatosi: ' + e.message);
    });
  } else {
    // Browser test
    alert('Yuborildi:\n' + payload);
  }
}

load();
</script>
</body>
</html>
