<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Narx kiriting</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: var(--tg-theme-bg-color, #fff);
  color: var(--tg-theme-text-color, #000);
  padding-bottom: 90px;
}
.header {
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  padding: 14px 16px 10px;
  position: sticky; top: 0; z-index: 10;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}
.header h1 { font-size: 17px; font-weight: 600; }
.header p  { font-size: 12px; opacity: .55; margin-top: 2px; }
.progress-bar { height: 3px; background: var(--tg-theme-secondary-bg-color, #f2f2f7); }
.progress-fill { height: 100%; background: var(--tg-theme-button-color, #007aff); transition: width .3s; }
.loading {
  display: flex; align-items: center; justify-content: center;
  padding: 60px 16px; flex-direction: column; gap: 12px;
  color: var(--tg-theme-hint-color, #888); font-size: 14px;
}
.spinner {
  width: 28px; height: 28px;
  border: 2.5px solid var(--tg-theme-secondary-bg-color, #ddd);
  border-top-color: var(--tg-theme-button-color, #007aff);
  border-radius: 50%; animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.item { border-bottom: 1px solid rgba(0,0,0,0.07); padding: 12px 16px; }
.item.unavail { opacity: .45; }
.item-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.item-num {
  width: 26px; height: 26px; border-radius: 50%;
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  color: var(--tg-theme-hint-color, #888);
  font-size: 11px; font-weight: 600;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.item-num.done { background: #E2EFDA; color: #3B6D11; }
.item-name { font-size: 15px; font-weight: 600; flex: 1; }
.item-qty  { font-size: 12px; color: var(--tg-theme-hint-color, #888); white-space: nowrap; }
.price-row { display: flex; align-items: center; gap: 8px; }
.price-wrap { flex: 1; position: relative; }
.price-input {
  width: 100%; height: 40px;
  border: 1.5px solid rgba(0,0,0,0.12); border-radius: 10px;
  font-size: 16px; font-weight: 500;
  padding: 0 56px 0 12px;
  background: var(--tg-theme-bg-color, #fff);
  color: var(--tg-theme-text-color, #000);
  outline: none; -webkit-appearance: none;
}
.price-input:focus { border-color: var(--tg-theme-button-color, #007aff); }
.price-input.filled { border-color: #3B6D11; }
.price-suffix {
  position: absolute; right: 10px; top: 50%;
  transform: translateY(-50%);
  font-size: 11px; color: var(--tg-theme-hint-color, #888); pointer-events: none;
}
.price-hint { font-size: 12px; color: #3B6D11; margin-top: 4px; font-weight: 500; display: none; }
.unavail-btn {
  height: 40px; padding: 0 10px;
  border: 1.5px solid rgba(0,0,0,0.10); border-radius: 10px;
  font-size: 12px; background: transparent;
  color: var(--tg-theme-hint-color, #888);
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
}
.unavail-btn.active { background: #FCEBEB; border-color: #F09595; color: #A32D2D; }
.note-input {
  width: 100%; margin-top: 8px;
  border: 1.5px solid rgba(0,0,0,0.08); border-radius: 10px;
  font-size: 14px; padding: 8px 12px;
  background: var(--tg-theme-secondary-bg-color, #f2f2f7);
  color: var(--tg-theme-text-color, #000);
  outline: none; resize: none; font-family: inherit; min-height: 36px;
}
.dl-row { padding: 10px 16px; border-bottom: 1px solid rgba(0,0,0,0.07); }
.dl-label { font-size: 13px; opacity: .55; margin-bottom: 8px; }
.chips { display: flex; gap: 8px; flex-wrap: wrap; }
.chip {
  padding: 6px 14px; border-radius: 16px;
  border: 1px solid rgba(0,0,0,0.12);
  font-size: 13px; font-weight: 500;
  cursor: pointer; background: transparent;
  color: var(--tg-theme-text-color, #000);
}
.chip.sel { background: var(--tg-theme-button-color, #007aff); color: #fff; border-color: transparent; }
.bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 8px 16px 12px;
  background: var(--tg-theme-bg-color, #fff);
  border-top: 1px solid rgba(0,0,0,0.08); z-index: 20;
}
.bottom-info { display: flex; justify-content: space-between; font-size: 12px; color: var(--tg-theme-hint-color,#888); margin-bottom: 8px; }
.total-sum { font-weight: 600; color: var(--tg-theme-button-color, #007aff); }
.send-btn {
  width: 100%; padding: 14px; border: none; border-radius: 12px;
  background: var(--tg-theme-button-color, #007aff);
  color: var(--tg-theme-button-text-color, #fff);
  font-size: 16px; font-weight: 600; cursor: pointer;
}
.send-btn:active { opacity: .8; }
.send-btn:disabled { opacity: .35; cursor: not-allowed; }
</style>
</head>
<body>

<div class="header">
  <h1>💰 Narx kiriting</h1>
  <p id="subtitle">Yuklanmoqda...</p>
</div>
<div class="progress-bar"><div class="progress-fill" id="progress" style="width:0%"></div></div>

<div id="content"><div class="loading"><div class="spinner"></div>Yuklanmoqda...</div></div>

<div class="dl-row">
  <div class="dl-label">🚚 Yetkazib berish muddati:</div>
  <div class="chips">
    <button class="chip sel" data-val="2"   onclick="selDel(this)">⚡️ 2 soat</button>
    <button class="chip"     data-val="24"  onclick="selDel(this)">🕐 24 soat</button>
    <button class="chip"     data-val="48"  onclick="selDel(this)">📅 2 kun</button>
    <button class="chip"     data-val="168" onclick="selDel(this)">🗓 1 hafta</button>
  </div>
</div>

<div class="bottom">
  <div class="bottom-info">
    <span id="filled-count">0/0</span>
    <span class="total-sum" id="total-sum"></span>
  </div>
  <button class="send-btn" id="send-btn" onclick="send()" disabled>Narx kiriting</button>
</div>

<script>
var tg       = window.Telegram && window.Telegram.WebApp;
var batchId  = 0;
var delivery = 2;
var needs    = [];

// batch_id — URL path dan olish: /offer/42 → 42
var parts = window.location.pathname.split('/');
for (var i = 0; i < parts.length; i++) {
  var n = parseInt(parts[i]);
  if (n > 0) { batchId = n; break; }
}
// URL params dan ham tekshiramiz
var qp = new URLSearchParams(window.location.search);
if (!batchId && qp.get('batch_id')) batchId = parseInt(qp.get('batch_id'));

if (tg) { tg.ready(); tg.expand(); }

function load() {
  if (!batchId) { showErr("Buyurtma ID topilmadi (batch_id=" + batchId + ")"); return; }
  fetch('/api/needs/' + batchId)
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(d) {
      if (!d || d.length === 0) { showErr("Bu buyurtmada mahsulot yo'q yoki muddati tugagan."); return; }
      needs = d;
      render();
    })
    .catch(function(e) { showErr("Yuklab bo'lmadi: " + e.message); });
}

function showErr(msg) {
  document.getElementById('content').innerHTML = '<div class="loading">' + msg + '</div>';
  document.getElementById('subtitle').textContent = 'Xato';
}

function render() {
  document.getElementById('subtitle').textContent = needs.length + ' ta mahsulot';
  var html = '';
  for (var i = 0; i < needs.length; i++) {
    var n = needs[i];
    html += '<div class="item" id="item-' + n.id + '">' +
      '<div class="item-header">' +
        '<div class="item-num" id="num-' + n.id + '">' + (i+1) + '</div>' +
        '<div class="item-name">' + esc(n.name) + '</div>' +
        '<div class="item-qty">Kerak: ' + n.qty + ' ' + n.unit + '</div>' +
      '</div>' +
      '<div class="price-row">' +
        '<div class="price-wrap">' +
          '<input class="price-input" id="price-' + n.id + '" type="number" ' +
            'inputmode="numeric" placeholder="1 ' + n.unit + ' narxi..." min="0" ' +
            'oninput="onPrice(' + n.id + ',' + n.qty + ',\'' + n.unit + '\')">' +
          '<span class="price-suffix">so\'m/' + n.unit + '</span>' +
        '</div>' +
        '<button class="unavail-btn" id="unavail-' + n.id + '" onclick="toggleUnavail(' + n.id + ')">' +
          'Mavjud emas' +
        '</button>' +
      '</div>' +
      '<div class="price-hint" id="hint-' + n.id + '"></div>' +
      '<textarea class="note-input" id="note-' + n.id + '" placeholder="Izoh... (brend, sifat)" rows="1"></textarea>' +
    '</div>';
  }
  document.getElementById('content').innerHTML = html;
  refresh();
}

function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function onPrice(id, qty, unit) {
  var input = document.getElementById('price-' + id);
  var hint  = document.getElementById('hint-' + id);
  var val   = parseFloat(input.value) || 0;
  if (val > 0) {
    input.classList.add('filled');
    var unavBtn = document.getElementById('unavail-' + id);
    if (unavBtn) unavBtn.classList.remove('active');
    document.getElementById('item-' + id).classList.remove('unavail');
    if (hint) {
      hint.textContent = qty + ' ' + unit + ' x ' + val.toLocaleString() + ' = ' + (val*qty).toLocaleString() + " so'm";
      hint.style.display = 'block';
    }
  } else {
    input.classList.remove('filled');
    if (hint) hint.style.display = 'none';
  }
  refresh();
}

function toggleUnavail(id) {
  var btn   = document.getElementById('unavail-' + id);
  var input = document.getElementById('price-' + id);
  var item  = document.getElementById('item-' + id);
  var hint  = document.getElementById('hint-' + id);
  var isOn  = btn.classList.toggle('active');
  if (isOn) {
    input.value = ''; input.classList.remove('filled'); input.disabled = true;
    item.classList.add('unavail');
    if (hint) hint.style.display = 'none';
  } else {
    input.disabled = false; item.classList.remove('unavail');
    input.focus();
  }
  refresh();
}

function refresh() {
  var filled = 0; var total = 0;
  for (var i = 0; i < needs.length; i++) {
    var n      = needs[i];
    var inp    = document.getElementById('price-' + n.id);
    var unav   = document.getElementById('unavail-' + n.id);
    var num    = document.getElementById('num-' + n.id);
    var isUnav = unav && unav.classList.contains('active');
    var price  = inp ? (parseFloat(inp.value) || 0) : 0;
    if (isUnav) {
      filled++;
      if (num) { num.textContent = '—'; num.classList.add('done'); }
    } else if (price > 0) {
      filled++; total += price * n.qty;
      if (num) num.classList.add('done');
    } else {
      if (num) { num.textContent = i+1; num.classList.remove('done'); }
    }
  }
  var pct = needs.length > 0 ? Math.round(filled/needs.length*100) : 0;
  document.getElementById('progress').style.width = pct + '%';
  document.getElementById('filled-count').textContent = filled + '/' + needs.length + ' to\'ldirildi';
  var ts = document.getElementById('total-sum');
  ts.textContent = total > 0 ? 'Jami: ' + total.toLocaleString() + " so'm" : '';
  var btn = document.getElementById('send-btn');
  btn.disabled = filled === 0;
  btn.textContent = filled > 0 ? ('✅ ' + filled + ' ta taklif yuborish') : 'Narx kiriting';
}

function selDel(el) {
  document.querySelectorAll('.chip').forEach(function(c){ c.classList.remove('sel'); });
  el.classList.add('sel');
  delivery = parseInt(el.dataset.val);
}

function send() {
  var offers = [];
  for (var i = 0; i < needs.length; i++) {
    var n     = needs[i];
    var inp   = document.getElementById('price-' + n.id);
    var unav  = document.getElementById('unavail-' + n.id);
    var notEl = document.getElementById('note-' + n.id);
    var price = inp ? (parseFloat(inp.value) || 0) : 0;
    var isUnav= unav ? unav.classList.contains('active') : false;
    var note  = notEl ? (notEl.value || '').trim() : '';
    if (isUnav) {
      offers.push({need_id: n.id, price: 0, unavailable: true, note: note});
    } else if (price > 0) {
      offers.push({need_id: n.id, price: price, unavailable: false, note: note});
    }
  }
  if (offers.length === 0) return;

  var payload = {
    type:     'offer',
    batch_id: batchId,
    offers:   offers,
    delivery: delivery
  };

  var btn = document.getElementById('send-btn');
  btn.disabled = true;
  btn.textContent = '⏳ Yuklanmoqda...';

  // Telegram user_id ni olamiz
  var userId = 0;
  if (tg && tg.initDataUnsafe && tg.initDataUnsafe.user) {
    userId = tg.initDataUnsafe.user.id;
  }

  // Har doim API orqali yuboramiz — ishonchli yo'l
  fetch('/api/submit_offer', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      payload:   JSON.stringify(payload),
      user_id:   userId,
      init_data: tg ? tg.initData : ''
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.ok) {
      btn.textContent = '✅ Yuborildi!';
      setTimeout(function() { if (tg) tg.close(); }, 1500);
    } else {
      btn.disabled = false;
      btn.textContent = '✅ Taklif yuborish';
      alert('Xato: ' + (res.error || 'nomalum'));
    }
  })
  .catch(function(e) {
    btn.disabled = false;
    btn.textContent = '✅ Taklif yuborish';
    alert('Tarmoq xatosi: ' + e.message);
  });
}

load();
</script>
</body>
</html>
